# =============================================================================
# MoSPAMS Frontend - Local Development Environment
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Google OAuth Configuration (Optional for local)
# -----------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Multi-Tenancy Configuration (Local)
# -----------------------------------------------------------------------------
VITE_PLATFORM_ADMIN_HOSTS=admin.mospams.local
VITE_PUBLIC_HOSTS=mospams.local
VITE_TENANT_HOSTS=*.mospams.local

# =============================================================================
# LOCAL DEVELOPMENT SETUP
# =============================================================================
# 1. Copy this file to .env: cp .env.local.example .env
# 2. Start backend: cd Backend && php artisan serve
# 3. Start frontend: npm run dev
# 4. Access at: http://localhost:5173
# =============================================================================

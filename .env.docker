# =============================================================================
# MoSPAMS Docker Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:your_generated_app_key_here
APP_URL=https://api.yourdomain.com
APP_PORT=8000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_ROOT_PASSWORD=secure_root_password_change_me
DB_DATABASE=mospams_production
DB_USERNAME=mospams_user
DB_PASSWORD=secure_database_password_change_me
DB_PORT=3306

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=secure_redis_password_change_me
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS_PATTERNS=/^https:\\/\\/[a-z0-9-]+\\.yourdomain\\.com$/,/^https:\\/\\/[a-z0-9-]+\\.vercel\\.app$/

# -----------------------------------------------------------------------------
# Deployment Options
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true
SEED_DATABASE=false

# =============================================================================
# IMPORTANT: Generate APP_KEY before deployment
# Run: docker-compose run --rm app php artisan key:generate --show
# =============================================================================

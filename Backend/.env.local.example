# =============================================================================
# MoSPAMS - Local Development Environment
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="MoSPAMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mospams_db
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Cache & Queue Configuration
# -----------------------------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Redis Configuration (Optional for local)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail Configuration (Log driver for local)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mospams.local"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# CORS Configuration (Local Development)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000"
CORS_ALLOWED_ORIGINS_PATTERNS="/^http:\\/\\/[a-z0-9-]+\\.mospams\\.local:5173$/,/^https:\\/\\/[a-z0-9-]+\\.ngrok-free\\.app$/,/^https:\\/\\/[a-z0-9-]+\\.ngrok\\.dev$/"

# -----------------------------------------------------------------------------
# Sanctum Configuration
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# -----------------------------------------------------------------------------
# Google OAuth Configuration (Optional for local)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# -----------------------------------------------------------------------------
# Super Admin Account (Local Development)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@mospams.local
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME="System Administrator"

# -----------------------------------------------------------------------------
# Multi-Tenancy Configuration (Local)
# -----------------------------------------------------------------------------
TENANCY_ENFORCEMENT_MODE=shadow
TENANCY_BASE_DOMAIN=mospams.local
TENANCY_PLATFORM_HOSTS=admin.mospams.local
TENANCY_PUBLIC_HOSTS=mospams.local
TENANCY_API_HOSTS=api.mospams.local
TENANCY_ALLOW_LOCALHOST_FALLBACK=true
TENANCY_AUDIT_CHANNEL=stack
TENANCY_CACHE_PREFIX=shop
TENANCY_DOMAIN_VERIFICATION_TTL_MINUTES=30
SHOP_TRIAL_DAYS=14

# -----------------------------------------------------------------------------
# Payment Gateway (Leave empty for local)
# -----------------------------------------------------------------------------
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare (Leave empty for local)
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# =============================================================================
# LOCAL DEVELOPMENT SETUP
# =============================================================================
# 1. Copy this file to .env: cp .env.local.example .env
# 2. Generate APP_KEY: php artisan key:generate
# 3. Create database: CREATE DATABASE mospams_db;
# 4. Run migrations: php artisan migrate
# 5. Seed database: php artisan db:seed
# 6. Start server: php artisan serve
# =============================================================================

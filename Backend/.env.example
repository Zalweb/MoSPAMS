# =============================================================================
# MoSPAMS - Motorcycle Service and Parts Management System
# Environment Configuration Template
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="MoSPAMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mospams_production
DB_USERNAME=mospams_user
DB_PASSWORD=your_secure_database_password

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Cache & Queue Configuration
# -----------------------------------------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail Configuration
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# CORS Configuration
# Comma-separated list of allowed origins and patterns
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com"
CORS_ALLOWED_ORIGINS_PATTERNS="/^https:\\/\\/[a-z0-9-]+\\.yourdomain\\.com$/,/^https:\\/\\/[a-z0-9-]+\\.vercel\\.app$/"

# Development CORS (remove in production)
# CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000"
# CORS_ALLOWED_ORIGINS_PATTERNS="/^http:\\/\\/[a-z0-9-]+\\.mospams\\.local:5173$/"

# -----------------------------------------------------------------------------
# Sanctum Configuration
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com,admin.yourdomain.com

# -----------------------------------------------------------------------------
# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# -----------------------------------------------------------------------------
# Super Admin Account (First-time Setup)
# Change these credentials immediately after first login!
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_FULL_NAME="System Administrator"

# -----------------------------------------------------------------------------
# Multi-Tenancy Configuration
# -----------------------------------------------------------------------------
TENANCY_ENFORCEMENT_MODE=strict
TENANCY_BASE_DOMAIN=yourdomain.com
TENANCY_PLATFORM_HOSTS=admin.yourdomain.com
TENANCY_PUBLIC_HOSTS=yourdomain.com,www.yourdomain.com
TENANCY_API_HOSTS=api.yourdomain.com
TENANCY_ALLOW_LOCALHOST_FALLBACK=false
TENANCY_AUDIT_CHANNEL=daily
TENANCY_CACHE_PREFIX=shop
TENANCY_DOMAIN_VERIFICATION_TTL_MINUTES=30
SHOP_TRIAL_DAYS=14

# -----------------------------------------------------------------------------
# Payment Gateway - PayMongo (Philippines)
# Get credentials from: https://dashboard.paymongo.com/
# -----------------------------------------------------------------------------
PAYMONGO_SECRET_KEY=sk_live_your_secret_key
PAYMONGO_PUBLIC_KEY=pk_live_your_public_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# Cloudflare Configuration (Optional - for custom domains)
# Get credentials from: https://dash.cloudflare.com/profile/api-tokens
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# -----------------------------------------------------------------------------
# AWS S3 Configuration (Optional - for file storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Vite (Frontend Build Tool)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# [ ] Set APP_ENV=production
# [ ] Set APP_DEBUG=false
# [ ] Generate APP_KEY: php artisan key:generate
# [ ] Set strong DB_PASSWORD
# [ ] Configure MAIL_* settings
# [ ] Set FRONTEND_URL to your domain
# [ ] Configure CORS_ALLOWED_ORIGINS
# [ ] Set SANCTUM_STATEFUL_DOMAINS
# [ ] Configure Google OAuth credentials
# [ ] Change ADMIN_PASSWORD immediately after first login
# [ ] Set TENANCY_ENFORCEMENT_MODE=strict
# [ ] Configure PayMongo credentials (if using billing)
# [ ] Configure Cloudflare (if using custom domains)
# [ ] Set up Redis for caching and queues
# [ ] Configure SSL certificates
# [ ] Set up automated backups
# [ ] Configure monitoring and logging
# =============================================================================

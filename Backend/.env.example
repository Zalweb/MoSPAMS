APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL_PATTERN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mospams_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Admin User Configuration
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mospams.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME="System Administrator"

# Tenancy
TENANCY_ENFORCEMENT_MODE=shadow
TENANCY_BASE_DOMAIN=mospams.app
TENANCY_PLATFORM_HOSTS=admin.mospams.app,admin.mospams.local,admin.mospams.shop
TENANCY_PUBLIC_HOSTS=mospams.app,mospams.local,mospams.shop
TENANCY_API_HOSTS=api.mospams.app,api.mospams.local,api.mospams.shop
TENANCY_ALLOW_LOCALHOST_FALLBACK=true
TENANCY_AUDIT_CHANNEL=stack
TENANCY_CACHE_PREFIX=shop
TENANCY_DOMAIN_VERIFICATION_TTL_MINUTES=30
SHOP_TRIAL_DAYS=14

# Billing
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
